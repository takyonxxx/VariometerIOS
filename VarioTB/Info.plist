<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Vario TB</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Variometer, hız, irtifa ve rüzgar hesaplaması için GPS konumuna ihtiyaç var.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>Uçuş sırasında arka planda da konum takibi için kullanılır.</string>
	<key>NSMotionUsageDescription</key>
	<string>Barometrik variometer için hareket ve basınç sensörleri kullanılır.</string>
	<key>NSCameraUsageDescription</key>
	<string>Başka cihazlardan yarışma görevi veya waypoint listesi almak için QR kod kamerayla taranır.</string>
	<key>NSSiriUsageDescription</key>
	<string>Vario TB; uçuş kaydı, canlı takip ve simülatörü sesli komutla başlatıp durdurmak için Siri izni kullanır.</string>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSExceptionDomains</key>
		<dict>
			<key>livetrack24.com</key>
			<dict>
				<key>NSExceptionAllowsInsecureHTTPLoads</key>
				<true/>
				<key>NSIncludesSubdomains</key>
				<true/>
				<key>NSExceptionRequiresForwardSecrecy</key>
				<false/>
			</dict>
		</dict>
	</dict>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
	</dict>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<!-- variotb: our own private scheme, exclusively used for
			     deep-linked QR codes that we generate ourselves. iOS
			     Camera resolves variotb:// URLs unambiguously to this
			     app — no other paragliding app claims this scheme.
			     QR codes shared FROM Vario TB use this format.

			     We deliberately DO NOT claim the xctsk: scheme here.
			     XCTrack and Flyskyhy both publish that scheme, and
			     when multiple apps register the same URL scheme iOS
			     picks one (typically the most recently installed)
			     without showing the user a chooser. Claiming xctsk:
			     in Vario TB would cause iOS Camera to silently open
			     XCTrack/Flyskyhy QR codes in Vario TB instead of the
			     pilot's primary flight app — surprising and
			     unwelcome behaviour for users who already have
			     Flyskyhy as their default. Pilots can still import
			     xctsk: QR codes via the in-app QR scanner
			     (Yarışma Görevi → QR tara), which uses the camera
			     directly and parses xctsk: payloads without
			     touching the iOS deep-link resolver. -->
			<key>CFBundleURLName</key>
			<string>com.tbiliyor.VarioTB.variotb</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>variotb</string>
			</array>
		</dict>
	</array>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
		<string>gps</string>
		<string>location-services</string>
	</array>
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
		<string>location</string>
	</array>
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string></string>
		<key>UIImageName</key>
		<string></string>
	</dict>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIStatusBarHidden</key>
	<true/>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<false/>
	<key>UIUserInterfaceStyle</key>
	<string>Dark</string>
</dict>
</plist>
